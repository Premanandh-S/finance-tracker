# -----------------------------------------------------------------------
# Temporary and cache directories
# -----------------------------------------------------------------------
tmp/
**/tmp/
cache/
**/cache/

# -----------------------------------------------------------------------
# Ruby / Rails
# -----------------------------------------------------------------------
*.gem
*.rbc
/.config
/coverage/
/InstalledFiles
/pkg/
/spec/reports/
/spec/examples.txt
/test/tmp/
/test/version_tmp/
/log/
/vendor/bundle/

# Rails specific
backend/log/*.log
backend/tmp/
backend/storage/
backend/.byebug_history

# Environment and secrets
.env
.env.*
!.env.example
backend/config/secrets.yml
backend/config/master.key
backend/config/credentials/*.key

# Database
backend/db/*.sqlite3
backend/db/*.sqlite3-journal

# -----------------------------------------------------------------------
# Node / React (frontend)
# -----------------------------------------------------------------------
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/.env
frontend/.env.*
!frontend/.env.example

# Vite
frontend/.vite/

# -----------------------------------------------------------------------
# OS and editor artifacts
# -----------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/
*.iml
